# ==============================================================================
# S.I.R.E.N - Git Ignore Configuration
# Professional Forensic Data Protection
# ==============================================================================

# Forensic Evidence & Dumps (STRICT PROTECTION)
# ------------------------------------------------------------------------------
# We ignore the entire dumps directory to prevent accidental exposure of 
# volatile memory data (RAM), sensitive strings, or system hashes.
dumps/
!dumps/.gitkeep

# Acquisition Artifacts
# ------------------------------------------------------------------------------
*.raw
*.bin
*.dmp
*.mem
*.img

# Analysis Reports
# ------------------------------------------------------------------------------
*.txt
*.log
*.csv
*.json
*.sha256

# Development & OS Artifacts
# ------------------------------------------------------------------------------
# Linux/Arch Linux swap files
*.swp
*~
.fuse_hidden*
.directory
.Trash-*

# macOS/Windows compatibility
.DS_Store
Thumbs.db

# Forensic outputs
dumps/
*.bin
*.raw
*.txt
*.sha256

